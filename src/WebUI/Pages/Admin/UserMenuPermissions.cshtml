@page "{userId:int}"
@model WebUI.Pages.Admin.UserMenuPermissionsModel
@{
    ViewData["Title"] = "User Menu Permissions";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                    <h4 class="mb-sm-0">Menu Permissions - @Model.UserFullName</h4>
                    <div class="text-end">
                        <a href="/Admin/Peoples" class="btn btn-light">
                            <i class="mdi mdi-arrow-left"></i> Back to Peoples
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                        {
                            <div class="alert alert-success">@Model.SuccessMessage</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger">@Model.ErrorMessage</div>
                        }

                        <p class="text-muted mb-4">
                            Select the menus this user can access. Parent menus are shown automatically when a child menu is assigned.
                            Admin users always see all menus regardless of these settings.
                        </p>

                        <form method="post">
                            <input type="hidden" asp-for="UserId" />

                            <div class="permissions-list border rounded p-3" style="max-height: 520px; overflow-y: auto;">
                                @foreach (var menu in Model.Menus)
                                {
                                    var isChild = menu.ParentId.HasValue && menu.ParentId.Value > 0;
                                    <div class="form-check mb-2 @(isChild ? "ms-4" : "")">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedMenuIds"
                                               value="@menu.Id"
                                               id="menu_@menu.Id"
                                               @(Model.SelectedMenuIds.Contains(menu.Id) ? "checked" : null) />
                                        <label class="form-check-label" for="menu_@menu.Id">
                                            @menu.MenuName
                                            @if (isChild && !string.IsNullOrWhiteSpace(menu.ParentMenuName))
                                            {
                                                <small class="text-muted">(@menu.ParentMenuName)</small>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>

                            <div class="mt-4">
                                <button type="submit" class="btn btn-primary">
                                    <i class="mdi mdi-content-save"></i> Save Menu Permissions
                                </button>
                                <a href="/Admin/Peoples" class="btn btn-light ms-2">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
