@page
@model WebUI.Pages.Admin.AssignInstitutionModel
@{
    ViewData["Title"] = "Assign Institution";
    var jsonOptions = new System.Text.Json.JsonSerializerOptions
    {
        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
    };
    var assignedInstitutionsJson = System.Text.Json.JsonSerializer.Serialize(Model.AssignedInstitutions, jsonOptions);
    var selectedInstitutionIdsJson = System.Text.Json.JsonSerializer.Serialize(Model.SelectedInstitutionIds, jsonOptions);
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                    <div>
                        <h4 class="mb-sm-0">Assign Institution</h4>
                        <p class="text-muted mb-0">Select institutions for the user and save the updated assignment.</p>
                    </div>
                    <div class="text-end">
                        <a href="/Admin/Peoples" class="btn btn-outline-secondary">
                            <i class="mdi mdi-arrow-left"></i> Back to Peoples
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Person Name</label>
                                <div class="form-control bg-light">@Model.UserFullName</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Assigned Role</label>
                                <div class="form-control bg-light">@Model.RoleName</div>
                            </div>
                        </div>

                        <form method="post" asp-page-handler="Save" id="assignInstitutionForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="AssignmentsJson" id="assignmentsJson" />
                            <div id="selectedInstitutionInputs"></div>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h5 class="mb-1">Assigned Institution List</h5>
                                    <p class="text-muted mb-0">Default list of institutions currently assigned to this user.</p>
                                </div>
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addInstitutionModal">
                                    <i class="mdi mdi-plus"></i> Assign Institution
                                </button>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-bordered align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Division</th>
                                            <th>State</th>
                                            <th>District</th>
                                            <th>Block</th>
                                            <th>Village</th>
                                            <th>Institution Name</th>
                                            <th>Grade &amp; Section</th>
                                            <th style="width: 110px;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="assignedInstitutionTableBody"></tbody>
                                </table>
                            </div>

                            <div id="noAssignedInstitutions" class="alert alert-warning mt-3 d-none">
                                No institutions assigned yet.
                            </div>

                            <div class="mt-4 text-end">
                                <a href="/Admin/Peoples" class="btn btn-light me-2">Cancel</a>
                                <button type="submit" class="btn btn-primary">Save Assignment</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="addInstitutionModal" class="modal fade" tabindex="-1" aria-labelledby="addInstitutionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addInstitutionModalLabel">Assign Institution</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Division</label>
                        <select id="modalDivision" class="form-select">
                            <option value="">Select Division</option>
                            @foreach (var division in Model.Divisions)
                            {
                                if (division.Value == Model.CurrentDivisionId)
                                {
                                    <option value="@division.Value" selected>@division.Text</option>
                                }
                                else
                                {
                                    <option value="@division.Value">@division.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">State</label>
                        <select id="modalState" class="form-select">
                            <option value="">Select State</option>
                            @foreach (var state in Model.States)
                            {
                                if (state.Value == Model.CurrentStateId)
                                {
                                    <option value="@state.Value" selected>@state.Text</option>
                                }
                                else
                                {
                                    <option value="@state.Value">@state.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">District<span class="text-danger">*</span></label>
                        <select id="modalDistrict" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Block<span class="text-danger">*</span></label>
                        <select id="modalBlock" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Village<span class="text-danger">*</span></label>
                        <select id="modalVillage" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Institution Type<span class="text-danger">*</span></label>
                        <select id="modalInstitutionType" class="form-select">
                            <option value="">Select Institution Type</option>
                            @foreach (var item in Model.InstitutionTypes)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="modalInstitutionSearch" class="form-label">Filter Institution Name</label>
                    <input type="text" id="modalInstitutionSearch" class="form-control" placeholder="Search institution name..." />
                </div>

                <div id="modalInstitutionList" class="border rounded p-3 modal-institution-list"></div>
                <div id="modalInstitutionEmpty" class="alert alert-warning mt-3 d-none">
                    No institutions found for the selected district, block, village and institution type.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="saveModalInstitutions" class="btn btn-primary">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const assignedInstitutionTableBody = document.getElementById('assignedInstitutionTableBody');
            const noAssignedInstitutions = document.getElementById('noAssignedInstitutions');
            const selectedInstitutionInputs = document.getElementById('selectedInstitutionInputs');
            const assignmentsJsonInput = document.getElementById('assignmentsJson');
            const assignInstitutionForm = document.getElementById('assignInstitutionForm');
            const modalDivision = document.getElementById('modalDivision');
            const modalState = document.getElementById('modalState');
            const modalDistrict = document.getElementById('modalDistrict');
            const modalBlock = document.getElementById('modalBlock');
            const modalVillage = document.getElementById('modalVillage');
            const modalInstitutionType = document.getElementById('modalInstitutionType');
            const modalInstitutionList = document.getElementById('modalInstitutionList');
            const modalInstitutionEmpty = document.getElementById('modalInstitutionEmpty');
            const modalInstitutionSearch = document.getElementById('modalInstitutionSearch');
            const saveModalInstitutions = document.getElementById('saveModalInstitutions');

            const pageState = {
                id: @Model.Id,
                divisionId: @Model.CurrentDivisionId,
                stateId: @Model.CurrentStateId,
                districtId: @Model.CurrentDistrictId,
                blockId: @Model.CurrentBlockId,
                villageId: @Model.CurrentVillageId,
                institutionTypeId: @Model.CurrentInstitutionTypeId,
                assignedInstitutions: @Html.Raw(assignedInstitutionsJson),
                selectedInstitutionIds: @Html.Raw(selectedInstitutionIdsJson),
                availableInstitutions: [],
                editingInstitutionId: 0
            };

            function normalizeInstitution(item) {
                const value = Number(item.value ?? item.Value ?? 0);
                const text = item.text ?? item.Text ?? '';
                const gradeSections = (item.gradeSections || item.GradeSections || []).map(function (gs) {
                    return {
                        gradeId: Number(gs.gradeId ?? gs.GradeId ?? 0),
                        gradeName: gs.gradeName ?? gs.GradeName ?? '',
                        sections: gs.sections ?? gs.Sections ?? '',
                        availableSections: String(gs.sections ?? gs.Sections ?? '')
                            .split(',')
                            .map(function (s) { return s.trim(); })
                            .filter(Boolean),
                        selectedSections: []
                    };
                });

                return { value: value, text: text, gradeSections: gradeSections };
            }

            function createOption(select, value, text, selectedValue) {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = text;
                option.selected = String(value) === String(selectedValue);
                return option;
            }

            function formatGradeSectionSummary(gradeSections) {
                return (gradeSections || [])
                    .filter(function (gs) { return gs.gradeId && (gs.sections || (gs.selectedSections && gs.selectedSections.length)); })
                    .map(function (gs) {
                        const sections = gs.sections || (gs.selectedSections || []).join(',');
                        const name = gs.gradeName || ('Grade ' + gs.gradeId);
                        return name + ' (' + sections + ')';
                    })
                    .join(', ');
            }

            function syncAssignmentsJson() {
                const payload = pageState.assignedInstitutions.map(function (institution) {
                    return {
                        institutionId: institution.id,
                        gradeSections: (institution.gradeSections || [])
                            .filter(function (gs) {
                                const sections = gs.sections || (gs.selectedSections || []).join(',');
                                return gs.gradeId && sections;
                            })
                            .map(function (gs) {
                                return {
                                    gradeId: gs.gradeId,
                                    sections: gs.sections || (gs.selectedSections || []).join(','),
                                    gradeName: gs.gradeName || ''
                                };
                            })
                    };
                });

                assignmentsJsonInput.value = JSON.stringify(payload);
                selectedInstitutionInputs.innerHTML = '';
                pageState.selectedInstitutionIds = pageState.assignedInstitutions.map(function (x) { return x.id; });
                pageState.selectedInstitutionIds.forEach(function (id) {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'SelectedInstitutionIds';
                    input.value = id;
                    selectedInstitutionInputs.appendChild(input);
                });
            }

            function renderAssignedTable() {
                assignedInstitutionTableBody.innerHTML = '';

                pageState.assignedInstitutions.forEach(function (institution) {
                    const summary = institution.gradeSectionSummary || formatGradeSectionSummary(institution.gradeSections);
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td>${institution.divisionName || ''}</td>
                        <td>${institution.stateName || ''}</td>
                        <td>${institution.districtName || ''}</td>
                        <td>${institution.blockName || ''}</td>
                        <td>${institution.villageName || ''}</td>
                        <td>${institution.institutionName || ''}</td>
                        <td>${summary || '<span class="text-muted">Not set</span>'}</td>
                        <td>
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-outline-primary edit-assigned-institution" data-id="${institution.id}" title="Edit">
                                    <i class="mdi mdi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger remove-assigned-institution" data-id="${institution.id}" title="Remove">
                                    <i class="mdi mdi-delete"></i>
                                </button>
                            </div>
                        </td>
                    `;
                    assignedInstitutionTableBody.appendChild(row);
                });

                noAssignedInstitutions.classList.toggle('d-none', pageState.assignedInstitutions.length > 0);
                syncAssignmentsJson();
            }

            function populateSelect(select, items, selectedValue, placeholder) {
                select.innerHTML = '';
                select.appendChild(createOption(select, '', placeholder, ''));
                (items || []).forEach(function (item) {
                    const value = Number(item.value ?? item.Value ?? 0);
                    const text = item.text ?? item.Text ?? '';
                    select.appendChild(createOption(select, value, text, selectedValue));
                });
            }

            async function fetchJson(url) {
                const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!response.ok) {
                    throw new Error('Request failed');
                }
                return response.json();
            }

            async function loadDistricts(selectedDistrictId) {
                if (!pageState.divisionId || !pageState.stateId) {
                    populateSelect(modalDistrict, [], '', 'Select District');
                    return;
                }
                const data = await fetchJson(`?handler=DistrictListByDivision&divisionId=${pageState.divisionId}&stateId=${pageState.stateId}`);
                populateSelect(modalDistrict, data, selectedDistrictId, 'Select District');
            }

            async function loadStates(selectedStateId) {
                if (!pageState.divisionId) {
                    populateSelect(modalState, [], '', 'Select State');
                    pageState.stateId = 0;
                    return;
                }

                const data = await fetchJson(`?handler=StateListByDivision&divisionId=${pageState.divisionId}`);
                populateSelect(modalState, data, selectedStateId, 'Select State');
                pageState.stateId = Number(modalState.value || 0);
            }

            async function loadBlocks(selectedBlockId) {
                if (!modalDistrict.value) {
                    populateSelect(modalBlock, [], '', 'Select Block');
                    return;
                }
                const data = await fetchJson(`?handler=BlockListByDivision&divisionId=${pageState.divisionId}&districtId=${modalDistrict.value}`);
                populateSelect(modalBlock, data, selectedBlockId, 'Select Block');
            }

            async function loadVillages(selectedVillageId) {
                if (!modalBlock.value) {
                    populateSelect(modalVillage, [], '', 'Select Village');
                    return;
                }
                const data = await fetchJson(`?handler=VillageListByDivision&divisionId=${pageState.divisionId}&blockId=${modalBlock.value}`);
                populateSelect(modalVillage, data, selectedVillageId, 'Select Village');
            }

            function getExistingSelectionMap(institutionId) {
                const existing = pageState.assignedInstitutions.find(function (item) { return Number(item.id) === Number(institutionId); });
                const map = {};
                if (!existing || !existing.gradeSections) {
                    return map;
                }

                (existing.gradeSections || []).forEach(function (gs) {
                    const gradeId = Number(gs.gradeId ?? gs.GradeId ?? 0);
                    const sections = String(gs.sections ?? gs.Sections ?? '')
                        .split(',')
                        .map(function (s) { return s.trim(); })
                        .filter(Boolean);
                    map[gradeId] = sections;
                });
                return map;
            }

            function buildGradeSectionHtml(institution) {
                if (!institution.gradeSections || institution.gradeSections.length === 0) {
                    return '<div class="text-muted small mt-2 ms-4">No grades/sections configured for this institution.</div>';
                }

                const existingMap = getExistingSelectionMap(institution.value);
                const isChecked = pageState.selectedInstitutionIds.includes(institution.value)
                    || !!document.getElementById('modalInstitution_' + institution.value)?.checked;

                let html = `<div class="grade-section-panel mt-2 ms-4 ${isChecked ? '' : 'd-none'}" data-institution-id="${institution.value}">`;
                html += '<div class="row g-2"><div class="col-md-4 fw-semibold small">Grades</div><div class="col-md-8 fw-semibold small">Sections</div></div>';

                institution.gradeSections.forEach(function (grade) {
                    const selectedForGrade = existingMap[grade.gradeId] || [];
                    const gradeChecked = selectedForGrade.length > 0;
                    html += `
                        <div class="row g-2 align-items-center border-bottom py-2 grade-row" data-grade-id="${grade.gradeId}">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input modal-grade-checkbox" type="checkbox"
                                           data-institution-id="${institution.value}" data-grade-id="${grade.gradeId}"
                                           id="grade_${institution.value}_${grade.gradeId}" ${gradeChecked ? 'checked' : ''}>
                                    <label class="form-check-label" for="grade_${institution.value}_${grade.gradeId}">${grade.gradeName}</label>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="d-flex flex-wrap gap-3">
                                    ${(grade.availableSections || []).map(function (section) {
                                        const sectionChecked = selectedForGrade.indexOf(section) >= 0;
                                        return `
                                            <div class="form-check">
                                                <input class="form-check-input modal-section-checkbox" type="checkbox"
                                                       data-institution-id="${institution.value}" data-grade-id="${grade.gradeId}"
                                                       value="${section}" id="section_${institution.value}_${grade.gradeId}_${section}"
                                                       ${sectionChecked ? 'checked' : ''} ${gradeChecked ? '' : 'disabled'}>
                                                <label class="form-check-label" for="section_${institution.value}_${grade.gradeId}_${section}">${section}</label>
                                            </div>
                                        `;
                                    }).join('')}
                                </div>
                            </div>
                        </div>
                    `;
                });

                html += '</div>';
                return html;
            }

            function renderAvailableInstitutions() {
                const searchTerm = (modalInstitutionSearch.value || '').trim().toLowerCase();
                modalInstitutionList.innerHTML = '';

                const filtered = pageState.availableInstitutions.filter(function (institution) {
                    return !searchTerm || (institution.text || '').toLowerCase().includes(searchTerm);
                });

                filtered.forEach(function (institution) {
                    const wrapper = document.createElement('div');
                    wrapper.className = 'mb-3 pb-2 border-bottom';
                    const isChecked = pageState.selectedInstitutionIds.includes(institution.value);
                    wrapper.innerHTML = `
                        <div class="form-check">
                            <input class="form-check-input modal-institution-checkbox" type="checkbox"
                                   value="${institution.value}" id="modalInstitution_${institution.value}" ${isChecked ? 'checked' : ''}>
                            <label class="form-check-label fw-semibold" for="modalInstitution_${institution.value}">${institution.text}</label>
                        </div>
                        ${buildGradeSectionHtml(institution)}
                    `;
                    modalInstitutionList.appendChild(wrapper);
                });

                modalInstitutionEmpty.classList.toggle('d-none', filtered.length > 0);
            }

            function collectModalSelections() {
                const selected = [];
                document.querySelectorAll('.modal-institution-checkbox:checked').forEach(function (checkbox) {
                    const institutionId = Number(checkbox.value);
                    const institution = pageState.availableInstitutions.find(function (item) {
                        return Number(item.value) === institutionId;
                    });
                    if (!institution) {
                        return;
                    }

                    const gradeSections = [];
                    (institution.gradeSections || []).forEach(function (grade) {
                        const gradeCheckbox = document.getElementById(`grade_${institutionId}_${grade.gradeId}`);
                        if (!gradeCheckbox || !gradeCheckbox.checked) {
                            return;
                        }

                        const sections = Array.from(document.querySelectorAll(
                            `.modal-section-checkbox[data-institution-id="${institutionId}"][data-grade-id="${grade.gradeId}"]:checked`
                        )).map(function (input) { return input.value; });

                        if (sections.length > 0) {
                            gradeSections.push({
                                gradeId: grade.gradeId,
                                gradeName: grade.gradeName,
                                sections: sections.join(',')
                            });
                        }
                    });

                    selected.push({
                        institution: institution,
                        gradeSections: gradeSections
                    });
                });
                return selected;
            }

            async function loadInstitutions() {
                if (!modalVillage.value || !modalInstitutionType.value) {
                    pageState.availableInstitutions = [];
                    renderAvailableInstitutions();
                    return;
                }

                const data = await fetchJson(`?handler=InstitutionsByVillageId&villageId=${modalVillage.value}&institutionTypeId=${modalInstitutionType.value}`);
                pageState.availableInstitutions = (data || []).map(normalizeInstitution);
                renderAvailableInstitutions();
            }

            async function initializeModal() {
                const isEdit = pageState.editingInstitutionId > 0;
                document.getElementById('addInstitutionModalLabel').textContent =
                    isEdit ? 'Edit Institution Assignment' : 'Assign Institution';

                modalDivision.value = String(pageState.divisionId || '');
                await loadStates(pageState.stateId);
                await loadDistricts(pageState.districtId);
                await loadBlocks(pageState.blockId);
                await loadVillages(pageState.villageId);
                modalInstitutionType.value = String(pageState.institutionTypeId || '');
                await loadInstitutions();

                if (isEdit) {
                    const checkbox = document.getElementById('modalInstitution_' + pageState.editingInstitutionId);
                    if (checkbox) {
                        checkbox.checked = true;
                        checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                        checkbox.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                    }
                }
            }

            modalDivision.addEventListener('change', async function () {
                pageState.divisionId = Number(modalDivision.value || 0);
                pageState.stateId = 0;
                pageState.districtId = 0;
                pageState.blockId = 0;
                pageState.villageId = 0;

                await loadStates('');
                populateSelect(modalDistrict, [], '', 'Select District');
                populateSelect(modalBlock, [], '', 'Select Block');
                populateSelect(modalVillage, [], '', 'Select Village');
                pageState.availableInstitutions = [];
                renderAvailableInstitutions();
            });

            modalState.addEventListener('change', async function () {
                pageState.stateId = Number(modalState.value || 0);
                pageState.districtId = 0;
                pageState.blockId = 0;
                pageState.villageId = 0;

                await loadDistricts('');
                populateSelect(modalBlock, [], '', 'Select Block');
                populateSelect(modalVillage, [], '', 'Select Village');
                pageState.availableInstitutions = [];
                renderAvailableInstitutions();
            });

            modalDistrict.addEventListener('change', async function () {
                pageState.districtId = Number(modalDistrict.value || 0);
                await loadBlocks('');
                populateSelect(modalVillage, [], '', 'Select Village');
                pageState.availableInstitutions = [];
                renderAvailableInstitutions();
            });

            modalBlock.addEventListener('change', async function () {
                pageState.blockId = Number(modalBlock.value || 0);
                await loadVillages('');
                pageState.availableInstitutions = [];
                renderAvailableInstitutions();
            });

            modalVillage.addEventListener('change', function () {
                pageState.villageId = Number(modalVillage.value || 0);
                loadInstitutions();
            });
            modalInstitutionType.addEventListener('change', loadInstitutions);
            modalInstitutionSearch.addEventListener('input', renderAvailableInstitutions);

            modalInstitutionList.addEventListener('change', function (event) {
                const target = event.target;
                if (target.classList.contains('modal-institution-checkbox')) {
                    const panel = modalInstitutionList.querySelector(`.grade-section-panel[data-institution-id="${target.value}"]`);
                    if (panel) {
                        panel.classList.toggle('d-none', !target.checked);
                    }
                    if (!target.checked) {
                        panel?.querySelectorAll('input[type="checkbox"]').forEach(function (input) {
                            input.checked = false;
                            if (input.classList.contains('modal-section-checkbox')) {
                                input.disabled = true;
                            }
                        });
                    }
                }

                if (target.classList.contains('modal-grade-checkbox')) {
                    const institutionId = target.dataset.institutionId;
                    const gradeId = target.dataset.gradeId;
                    const sectionInputs = modalInstitutionList.querySelectorAll(
                        `.modal-section-checkbox[data-institution-id="${institutionId}"][data-grade-id="${gradeId}"]`
                    );
                    sectionInputs.forEach(function (input) {
                        input.disabled = !target.checked;
                        if (!target.checked) {
                            input.checked = false;
                        }
                    });
                }

                if (target.classList.contains('modal-section-checkbox') && target.checked) {
                    const gradeCheckbox = document.getElementById(`grade_${target.dataset.institutionId}_${target.dataset.gradeId}`);
                    if (gradeCheckbox) {
                        gradeCheckbox.checked = true;
                        modalInstitutionList.querySelectorAll(
                            `.modal-section-checkbox[data-institution-id="${target.dataset.institutionId}"][data-grade-id="${target.dataset.gradeId}"]`
                        ).forEach(function (input) { input.disabled = false; });
                    }
                }
            });

            saveModalInstitutions.addEventListener('click', function () {
                const selections = collectModalSelections();
                if (selections.length === 0 && pageState.editingInstitutionId <= 0) {
                    alert('Please select at least one institution.');
                    return;
                }

                for (let i = 0; i < selections.length; i++) {
                    if (!selections[i].gradeSections.length) {
                        alert('Please select at least one grade and section for each selected institution.');
                        return;
                    }
                }

                const divisionText = modalDivision.options[modalDivision.selectedIndex]?.text || '';
                const stateText = modalState.options[modalState.selectedIndex]?.text || '';
                const districtText = modalDistrict.options[modalDistrict.selectedIndex]?.text || '';
                const blockText = modalBlock.options[modalBlock.selectedIndex]?.text || '';
                const villageText = modalVillage.options[modalVillage.selectedIndex]?.text || '';

                const visibleIds = pageState.availableInstitutions.map(function (item) { return Number(item.value); });
                const selectedIdsInModal = selections.map(function (item) { return Number(item.institution.value); });

                // Remove any visible institutions that were unchecked in this modal session.
                pageState.assignedInstitutions = pageState.assignedInstitutions.filter(function (item) {
                    const id = Number(item.id);
                    if (visibleIds.indexOf(id) < 0) {
                        return true;
                    }
                    return selectedIdsInModal.indexOf(id) >= 0;
                });

                selections.forEach(function (selection) {
                    const institutionId = selection.institution.value;
                    const existingIndex = pageState.assignedInstitutions.findIndex(function (item) {
                        return Number(item.id) === institutionId;
                    });

                    const row = {
                        id: institutionId,
                        divisionId: pageState.divisionId,
                        stateId: pageState.stateId,
                        districtId: Number(modalDistrict.value || 0),
                        blockId: Number(modalBlock.value || 0),
                        villageId: Number(modalVillage.value || 0),
                        institutionTypeId: Number(modalInstitutionType.value || 0),
                        divisionName: divisionText,
                        stateName: stateText,
                        districtName: districtText,
                        blockName: blockText,
                        villageName: villageText,
                        institutionName: selection.institution.text,
                        gradeSections: selection.gradeSections,
                        gradeSectionSummary: formatGradeSectionSummary(selection.gradeSections)
                    };

                    if (existingIndex >= 0) {
                        pageState.assignedInstitutions[existingIndex] = row;
                    } else {
                        pageState.assignedInstitutions.push(row);
                    }
                });

                pageState.selectedInstitutionIds = pageState.assignedInstitutions.map(function (x) { return x.id; });
                pageState.editingInstitutionId = 0;
                renderAssignedTable();
                bootstrap.Modal.getInstance(document.getElementById('addInstitutionModal')).hide();
            });

            assignedInstitutionTableBody.addEventListener('click', function (event) {
                const editButton = event.target.closest('.edit-assigned-institution');
                if (editButton) {
                    const institutionId = Number(editButton.dataset.id);
                    const institution = pageState.assignedInstitutions.find(function (item) {
                        return Number(item.id) === institutionId;
                    });
                    if (!institution) {
                        return;
                    }

                    pageState.editingInstitutionId = institutionId;
                    pageState.divisionId = Number(institution.divisionId || pageState.divisionId || 0);
                    pageState.stateId = Number(institution.stateId || pageState.stateId || 0);
                    pageState.districtId = Number(institution.districtId || 0);
                    pageState.blockId = Number(institution.blockId || 0);
                    pageState.villageId = Number(institution.villageId || 0);
                    pageState.institutionTypeId = Number(institution.institutionTypeId || 0);

                    const modalElement = document.getElementById('addInstitutionModal');
                    const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
                    modal.show();
                    return;
                }

                const button = event.target.closest('.remove-assigned-institution');
                if (!button) {
                    return;
                }

                const institutionId = Number(button.dataset.id);
                pageState.selectedInstitutionIds = pageState.selectedInstitutionIds.filter(function (id) {
                    return id !== institutionId;
                });
                pageState.assignedInstitutions = pageState.assignedInstitutions.filter(function (institution) {
                    return institution.id !== institutionId;
                });
                renderAssignedTable();
            });

            document.querySelector('[data-bs-target="#addInstitutionModal"]')?.addEventListener('click', function () {
                pageState.editingInstitutionId = 0;
            });

            document.getElementById('addInstitutionModal').addEventListener('show.bs.modal', function () {
                modalInstitutionSearch.value = '';
                initializeModal();
            });

            document.getElementById('addInstitutionModal').addEventListener('hidden.bs.modal', function () {
                pageState.editingInstitutionId = 0;
                document.getElementById('addInstitutionModalLabel').textContent = 'Assign Institution';
            });

            assignInstitutionForm.addEventListener('submit', function () {
                syncAssignmentsJson();
            });

            renderAssignedTable();
        })();
    </script>
    <style>
        .modal-institution-list {
            max-height: 420px;
            overflow-y: auto;
        }
        .grade-section-panel {
            background: #f8f9fa;
            border-radius: 0.25rem;
            padding: 0.75rem;
        }
    </style>
}

